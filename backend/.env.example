# Neon (or any PostgreSQL) connection string
# Get from Neon dashboard: Project → Connection details
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Or use individual vars for local PostgreSQL:
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=postgres
# PG_DATABASE=agilite
